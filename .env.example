# Copy to .env for Docker runs.
# Telegram token comes from @BotFather.
TELEGRAM_BOT_TOKEN=replace_me

# Local Ollama does not require a real key; OpenClaw expects a marker value.
OLLAMA_API_KEY=ollama-local

# Local Ollama model used in this test task.
OPENCLAW_MODEL=hf.co/empero-ai/Qwythos-9B-Claude-Mythos-5-1M-GGUF:Q4_K_M
