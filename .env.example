# Скопируйте файл в .env для запуска через Docker.
# Telegram-токен берется у @BotFather.
TELEGRAM_BOT_TOKEN=заменить_на_токен_бота

# Для локальной Ollama реальный ключ не нужен; OpenClaw ожидает служебное значение.
OLLAMA_API_KEY=ollama-local

# Локальная Ollama-модель, использованная в тестовом задании.
OPENCLAW_MODEL=hf.co/empero-ai/Qwythos-9B-Claude-Mythos-5-1M-GGUF:Q4_K_M
